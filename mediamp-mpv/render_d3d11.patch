diff --git a/video/out/d3d11/libmpv_d3d11.c b/video/out/d3d11/libmpv_d3d11.c
new file mode 100644
index 0000000000000..a5a25bab67ebb
--- /dev/null
+++ b/video/out/d3d11/libmpv_d3d11.c
@@ -0,0 +1,109 @@
+/*
